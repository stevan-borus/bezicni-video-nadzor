---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bežični Video Nadzor | Laznik — Profesionalna Instalacija Bez Kablova',
  description = 'Profesionalni bežični sistemi video nadzora na solarno napajanje. Instalacija bez kablova, praćenje uživo sa telefona, pokrivenost udaljenih lokacija. Zakažite besplatnu konsultaciju.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Laznik — Bežični Video Nadzor',
  description,
  url: 'https://bezicnivideonadzor.rs',
  areaServed: {
    '@type': 'Country',
    name: 'Serbia',
  },
  serviceType: 'Video Surveillance Installation',
  knowsAbout: [
    'Bežični video nadzor',
    'Solarno napajanje kamera',
    'Profesionalna instalacija sigurnosnih sistema',
  ],
};
---

<!doctype html>
<html lang="sr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://bezicnivideonadzor.rs/images/hero-drone.webp" />
    <meta property="og:locale" content="sr_RS" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://bezicnivideonadzor.rs/images/hero-drone.webp" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
