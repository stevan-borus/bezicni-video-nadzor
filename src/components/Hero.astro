      aria-hidden="true"
    />
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-navy-950/70"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/30 to-navy-950/60"></div>
