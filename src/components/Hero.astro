<section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-900 to-navy-950"></div>

  <!-- Subtle radial glow -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-gold-500/5 rounded-full blur-3xl"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div class="text-center lg:text-left">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight">
          Znajte šta se dešava na vašem posedu —
          <span class="text-gold-500">u svakom trenutku, sa bilo kog mesta</span>
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-text-secondary leading-relaxed max-w-2xl mx-auto lg:mx-0">
          Profesionalni bežični sistemi video nadzora na solarno napajanje, instalirani za vas — bez kablova, bez komplikacija. Pratite, zaštitite i imajte potpunu kontrolu.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
          <a
            href="#contact"
            class="inline-flex items-center px-8 py-4 rounded-lg bg-gold-500 text-navy-950 font-bold text-lg hover:bg-gold-400 transition-colors shadow-lg shadow-gold-500/20"
          >
            Zakažite besplatnu konsultaciju
          </a>
          <a
            href="#problem"
            class="inline-flex items-center gap-2 text-text-secondary hover:text-gold-500 transition-colors font-medium"
          >
            Saznajte više
            <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Hero image -->
      <div class="relative">
        <div class="relative rounded-2xl overflow-hidden border border-navy-700/50 shadow-2xl">
          <img
            src="/images/hero-drone.webp"
            alt="Bežični video nadzor sistem instaliran na terenu — pogled iz drona"
            class="w-full h-auto object-cover"
            width="800"
            height="600"
            loading="eager"
          />
          <!-- Overlay gradient -->
          <div class="absolute inset-0 bg-gradient-to-t from-navy-950/40 to-transparent"></div>
        </div>

        <!-- Floating badge -->
        <div class="absolute -bottom-4 -left-4 sm:left-auto sm:-right-4 bg-navy-800 border border-navy-700/50 rounded-xl px-4 py-3 shadow-xl">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gold-500/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-text-primary">Solarno napajanje</p>
              <p class="text-xs text-text-secondary">Bez struje, bez kablova</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
