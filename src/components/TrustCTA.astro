---
const trustItems = [
  'Profesionalna instalacija (nije „uradi sam" rešenje)',
  'Prilagođeno vašem konkretnom objektu',
  'Pouzdana i kvalitetna oprema',
  'Podrška i nakon instalacije',
  'Namenjeno vlasnicima kuća i poslovnim korisnicima',
];
---

<section id="contact" class="py-20 lg:py-28 bg-navy-950">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 reveal">
    <!-- Trust badges -->
    <div class="max-w-3xl mx-auto mb-16">
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-4">
        {trustItems.map((item) => (
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-text-secondary">{item}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA + Contact Form -->
    <div class="max-w-4xl mx-auto reveal-scale">
      <div class="p-8 sm:p-12 rounded-2xl bg-gradient-to-b from-navy-800 to-navy-900 border border-navy-700/50 shadow-2xl">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-12">
          <!-- Left: CTA text -->
          <div>
            <h2 class="text-3xl sm:text-4xl font-bold">
              Zakažite <span class="text-gold-500">besplatnu procenu</span> bezbednosti
            </h2>
            <p class="mt-4 text-text-secondary text-lg leading-relaxed">
              Procenićemo vaš objekat, otkriti slabe tačke i preporučiti najbolje rešenje — bez obaveza i bez pritiska.
            </p>
            <p class="mt-6 text-sm text-text-secondary">
              Ili nas kontaktirajte direktno:
            </p>
            <div class="mt-3 space-y-2">
              <a href="tel:+381698500189" class="flex items-center gap-2 text-text-primary hover:text-gold-500 transition-colors">
                <svg class="w-4 h-4 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                +381 69 8500 189
              </a>
              <a href="mailto:info@laznik.net" class="flex items-center gap-2 text-text-primary hover:text-gold-500 transition-colors">
                <svg class="w-4 h-4 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                info@laznik.net
              </a>
            </div>
          </div>

          <!-- Right: Contact form -->
          <form id="contact-form" class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-medium text-text-secondary mb-1">Ime i prezime</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg bg-navy-950/50 border border-navy-700/50 text-text-primary placeholder-text-secondary/50 focus:outline-none focus:border-gold-500/50 focus:ring-1 focus:ring-gold-500/20 transition-colors"
                placeholder="Vaše ime"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-text-secondary mb-1">Telefon</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                pattern="[\+]?[0-9\s]{6,20}"
                title="Unesite validan broj telefona (samo cifre, + i razmaci)"
                class="w-full px-4 py-3 rounded-lg bg-navy-950/50 border border-navy-700/50 text-text-primary placeholder-text-secondary/50 focus:outline-none focus:border-gold-500/50 focus:ring-1 focus:ring-gold-500/20 transition-colors"
                placeholder="+381..."
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-text-secondary mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-4 py-3 rounded-lg bg-navy-950/50 border border-navy-700/50 text-text-primary placeholder-text-secondary/50 focus:outline-none focus:border-gold-500/50 focus:ring-1 focus:ring-gold-500/20 transition-colors"
                placeholder="vas@email.com"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-text-secondary mb-1">Poruka</label>
              <textarea
                id="message"
                name="message"
                rows="3"
                class="w-full px-4 py-3 rounded-lg bg-navy-950/50 border border-navy-700/50 text-text-primary placeholder-text-secondary/50 focus:outline-none focus:border-gold-500/50 focus:ring-1 focus:ring-gold-500/20 transition-colors resize-none"
                placeholder="Opišite šta vam je potrebno..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full px-8 py-4 rounded-lg bg-gold-500 text-navy-950 font-bold text-lg hover:bg-gold-400 transition-all shadow-lg shadow-gold-500/20 hover:shadow-gold-500/30 hover:scale-[1.02] cursor-pointer"
            >
              Pošaljite upit
            </button>

            <p class="text-xs text-text-secondary text-center">Bez obaveza. Odgovorićemo u roku od 24h.</p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Phone field: only allow +, digits, spaces, and dashes
  const phoneInput = document.getElementById('phone') as HTMLInputElement;
  phoneInput?.addEventListener('input', () => {
    phoneInput.value = phoneInput.value.replace(/[^\d+\s]/g, '');
  });

  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = data.get('name');
    const phone = data.get('phone');
    const email = data.get('email');
    const message = data.get('message');

    // Mailto fallback — works without a backend
    const subject = encodeURIComponent('Upit za bežični video nadzor');
    const body = encodeURIComponent(
      `Ime: ${name}\nTelefon: ${phone}\nEmail: ${email}\n\nPoruka:\n${message}`
    );
    window.location.href = `mailto:info@laznik.net?subject=${subject}&body=${body}`;
  });
</script>
