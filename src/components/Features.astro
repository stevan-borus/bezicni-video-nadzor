---
const features = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />`,
    title: 'HD / 4K kamere',
    description: 'Kristalno jasan snimak, danju i noću. Vidite svaki detalj na vašem posedu.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />`,
    title: 'Snimanje + skladištenje',
    description: 'Pristup prethodnim događajima kad god vam zatreba. Sigurno čuvanje snimaka.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />`,
    title: 'Profesionalna instalacija',
    description: 'Strateški postavljeno za maksimalnu pokrivenost. Bez bušenja, bez kablova.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />`,
    title: 'Solarno napajanje',
    description: 'Autonoman rad bez priključka na struju. Idealno za udaljene i teško pristupačne lokacije.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
    title: 'Mobilna aplikacija (24/7)',
    description: 'Proverite svoj objekat u svakom trenutku sa telefona — gde god da se nalazite.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />`,
    title: 'Obuka + podrška',
    description: 'Tačno ćete znati kako da koristite sistem. Podrška i nakon instalacije — bez tehničkog stresa.',
  },
];
---

<section id="features" class="py-20 lg:py-28 bg-navy-900">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-wider text-gold-500 mb-4">Šta dobijate</p>
      <h2 class="text-3xl sm:text-4xl font-bold">
        Kompletno rešenje za video nadzor — <span class="text-gold-500">bez kompromisa</span>
      </h2>
    </div>

    <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class="p-6 rounded-xl bg-navy-800/50 border-t-2 border-gold-500/60 hover:border-gold-500 transition-colors">
          <div class="w-12 h-12 rounded-lg bg-gold-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={feature.icon} />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-text-primary">{feature.title}</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href="#contact"
        class="inline-flex items-center px-8 py-4 rounded-lg bg-gold-500 text-navy-950 font-bold text-lg hover:bg-gold-400 transition-colors shadow-lg shadow-gold-500/20"
      >
        Zakažite besplatnu konsultaciju
      </a>
    </div>
  </div>
</section>
