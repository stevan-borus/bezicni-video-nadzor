---
const steps = [
  {
    title: 'Analiza i dokumentacija',
    description: 'Prikupljamo informacije o vašem objektu i identifikujemo slabe tačke.',
  },
  {
    title: 'Planiranje i projektovanje',
    description: 'Kreiramo prilagođen tehnički plan specifičan za vaše potrebe.',
  },
  {
    title: 'Usaglašavanje sa klijentom',
    description: 'Predstavljamo rešenje i prilagođavamo plan po vašim željama.',
  },
  {
    title: 'Proizvodnja solarnih stubova',
    description: 'Izrađujemo robusnu infrastrukturu po meri — stubove sa solarnim napajanjem.',
  },
  {
    title: 'Instalacija i konfiguracija',
    description: 'Profesionalna ugradnja na terenu. Bez bušenja, bez kablova.',
  },
  {
    title: 'Puštanje u rad i garancija',
    description: 'Testiramo sistem, obučavamo vas i pružamo garanciju na opremu.',
  },
];
---

<section id="process" class="py-20 lg:py-28 bg-navy-900">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 reveal">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-wider text-gold-500 mb-4">Kako radimo</p>
      <h2 class="text-3xl sm:text-4xl font-bold">
        Od analize do zaštite — <span class="text-gold-500">u 6 koraka</span>
      </h2>
    </div>

    <div class="mt-16 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center max-w-6xl mx-auto">
      <!-- Timeline -->
      <div class="reveal-left">
        {steps.map((step, i) => (
          <div class="flex gap-6 group">
            <div class="flex flex-col items-center">
              <div class="w-10 h-10 rounded-full bg-gold-500/10 border-2 border-gold-500/40 group-hover:border-gold-500 flex items-center justify-center transition-colors">
                <span class="text-sm font-bold text-gold-500">{String(i + 1).padStart(2, '0')}</span>
              </div>
              {i < steps.length - 1 && (
                <div class="w-px flex-1 bg-navy-700/50 my-2"></div>
              )}
            </div>
            <div class:list={["pb-8", i === steps.length - 1 && "pb-0"]}>
              <h3 class="text-lg font-semibold text-text-primary">{step.title}</h3>
              <p class="mt-1 text-text-secondary leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Image -->
      <div class="reveal-right hidden lg:block">
        <div class="relative rounded-2xl overflow-hidden border border-navy-700/50 shadow-2xl">
          <img
            src="/images/installation.jpg"
            alt="Instalacija bežičnog video nadzora — solarni stub sa kamerom"
            class="w-full h-auto object-cover"
            width="600"
            height="600"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-navy-900/50 to-transparent"></div>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center">
      <a href="#contact" class="text-gold-500 hover:text-gold-400 font-medium transition-colors">
        Započnite proces danas →
      </a>
    </div>
  </div>
</section>
